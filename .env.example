# Office Jukebox local configuration
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Optional. If omitted, the frontend calls the current origin and Vite proxies /api in dev.
# VITE_API_URL=http://localhost:5000

# Windows/NTLM authentication
NTLM_DOMAIN=YOUR_DOMAIN
NTLM_DOMAIN_CONTROLLER=ldap://dc.yourdomain.local
# NTLM_DEBUG=false

# Spotify shared office account
SPOTIFY_CLIENT_ID=your-client-id
SPOTIFY_CLIENT_SECRET=your-client-secret
SPOTIFY_REFRESH_TOKEN=your-refresh-token

# OAuth setup helper. Register this redirect URI in the Spotify app.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
