{
  "name": "office-jukebox",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-ntlm": "^2.7.0",
    "lucide-react": "^1.11.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "scripts": {
    "start": "node server/index.js --serve-static",
    "build": "vite build",
    "server": "nodemon --watch server --ext js,json server/index.js",
    "client": "vite",
    "dev": "concurrently \"cross-env PORT=5000 npm run server\" \"npm run client\"",
    "spotify:auth": "node scripts/spotify-auth.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "heroku-postbuild": "npm run build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "jsdom": "^24.1.3",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  }
}
